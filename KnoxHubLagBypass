local function createSlider(y, text, initialValue, minVal, maxVal, valueToRel, relToValue)
	local holder = Instance.new("Frame", main)
	holder.Size = UDim2.fromOffset(170, 36)
	holder.Position = UDim2.new(0.5, -85, 0, y)
	holder.BackgroundTransparency = 1

	local label = Instance.new("TextLabel", holder)
	label.Size = UDim2.new(1, 0, 0, 14)
	label.BackgroundTransparency = 1
	label.Text = text .. initialValue
	label.Font = Enum.Font.Gotham
	label.TextSize = 11
	label.TextColor3 = Color3.new(1, 1, 1)

	local bar = Instance.new("Frame", holder)
	bar.Size = UDim2.fromOffset(170, 5)
	bar.Position = UDim2.fromOffset(0, 19)
	bar.BackgroundColor3 = Color3.fromRGB(80, 10, 10)
	bar.BorderSizePixel = 0
	Instance.new("UICorner", bar).CornerRadius = UDim.new(1, 0)

	local fill = Instance.new("Frame", bar)
	fill.Size = UDim2.fromScale(0, 1)
	fill.BackgroundColor3 = Color3.fromRGB(255, 80, 80)
	fill.BorderSizePixel = 0
	Instance.new("UICorner", fill).CornerRadius = UDim.new(1, 0)

	local knob = Instance.new("Frame", bar)
	knob.Size = UDim2.fromOffset(11, 11)
	knob.AnchorPoint = Vector2.new(0.5, 0.5)
	knob.Position = UDim2.new(0, 0, 0.5, 0)
	knob.BackgroundColor3 = Color3.fromRGB(255, 120, 120)
	Instance.new("UICorner", knob).CornerRadius = UDim.new(1, 0)

	local rel = valueToRel(initialValue)
	fill.Size = UDim2.fromScale(rel, 1)
	knob.Position = UDim2.new(rel, 0, 0.5, 0)
	label.Text = text .. initialValue

	return holder, bar, fill, knob, label, function(r)
		local val = relToValue(r)
		label.Text = text .. val
		return val
	end
end

local lagHolder, lagBar, lagFill, lagKnob, lagLabel, lagUpdate = createSlider(
	62, "Lag: ", math.floor(lagAmount * 100), 0, 100,
	function(val) return val / 100 end,
	function(rel) return math.floor(rel * 100) end
)

local speedHolder, speedBar, speedFill, speedKnob, speedLabel, speedUpdate = createSlider(
	96, "Speed: ", speedAmount, 16, 100,
	function(val) return (val - 16) / 84 end,
	function(rel) return math.floor(16 + rel * 84) end
)

local draggingUI = false
local draggingSlider = nil
local dragStart, startPos

local function updateSliderRaw(bar, fill, knob, x)
	local rel = math.clamp((x - bar.AbsolutePosition.X) / bar.AbsoluteSize.X, 0, 1)
	fill.Size = UDim2.fromScale(rel, 1)
	knob.Position = UDim2.new(rel, 0, 0.5, 0)
	return rel
end

local function hookSlider(holder, bar, fill, knob, isLagSlider)
	bar.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			draggingSlider = {bar, fill, knob, isLagSlider}
		end
	end)
	knob.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			draggingSlider = {bar, fill, knob, isLagSlider}
		end
	end)
	holder.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			draggingUI = false
		end
	end)
end

hookSlider(lagHolder, lagBar, lagFill, lagKnob, true)
hookSlider(speedHolder, speedBar, speedFill, speedKnob, false)

UIS.InputChanged:Connect(function(input)
	if draggingSlider and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
		local rel = updateSliderRaw(draggingSlider[1], draggingSlider[2], draggingSlider[3], input.Position.X)
		if draggingSlider[4] then
			lagAmount = rel
			lagLabel.Text = "Lag: " .. math.floor(rel * 100) .. "%"
		else
			speedAmount = math.floor(16 + rel * 84)
			speedLabel.Text = "Speed: " .. speedAmount
		end
		saveConfig({
			isEnabled = isEnabled,
			lagAmount = lagAmount,
			speedAmount = speedAmount
		})
	end

	if draggingUI and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
		local delta = input.Position - dragStart
		main.Position = UDim2.new(
			startPos.X.Scale,
			startPos.X.Offset + delta.X,
			startPos.Y.Scale,
			startPos.Y.Offset + delta.Y
		)
	end
end)

UIS.InputEnded:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
		draggingSlider = nil
		draggingUI = false
	end
end)

topBar.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
		if not draggingSlider then
			draggingUI = true
			dragStart = input.Position
			startPos = main.Position
		end
	end
end)

RunService.RenderStepped:Connect(function()
	if not isEnabled then return end

	if lagAmount > 0 then
		local t = tick()
		local blockTime = lagAmount * 0.1
		while tick() - t < blockTime do end
	end

	local char = player.Character
	if char then
		local root = char:FindFirstChild("HumanoidRootPart")
		local hum = char:FindFirstChildOfClass("Humanoid")
		if root and hum and hum.MoveDirection.Magnitude > 0 then
			local direction = hum.MoveDirection.Unit
			local currentY = root.AssemblyLinearVelocity.Y
			root.AssemblyLinearVelocity = Vector3.new(
				direction.X * speedAmount,
				currentY,
				direction.Z * speedAmount
			)
		end
	end
end)
